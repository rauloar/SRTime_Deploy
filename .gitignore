# ── SRTime .gitignore ─────────────────────────────────────────
# El proyecto vive en attendance/. Todo lo demás es excluido.

# ── Carpetas externas al proyecto ─────────────────────────────
att/
backup/
build/
dist/
pyzk/
deploy/dist/
deploy/build/

# ── Virtual Environments ─────────────────────────────────────
env/
venv/
ENV/
.venv/

# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
*.egg
*.pot
*.spec
.pytest_cache/
.coverage
htmlcov/
.tox/

# ── IDE ───────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── Environment variables ────────────────────────────────────
.env
.env.local
.env.*.local

# ── Logs ──────────────────────────────────────────────────────
*.log

# ── Database files (local development) ───────────────────────
*.db
*.sqlite
*.sqlite3

# ── OS ────────────────────────────────────────────────────────
Thumbs.db
.DS_Store

# ── Backup and temporary files ───────────────────────────────
*.bak
*.tmp
_git_status.txt

# ── Node.js / Next.js (frontend) ─────────────────────────────
attendance/web/node_modules/
attendance/web/.next/
attendance/web/out/
attendance/web/.cache/

# ── Application logs directory ────────────────────────────────
attendance/logs/

# ── Legacy / generated docs ──────────────────────────────────
CLEANUP_EXECUTED.md
test_results.html
coverage.xml
