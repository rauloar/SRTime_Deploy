# ============================================================
# SRTime - Environment Variables Template
# Copy this file to .env and fill in your values
# ============================================================

# PostgreSQL Connection
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=your_password_here
DB_NAME=attendance

# FastAPI JWT Secret Key (generate a strong random key for production)
# To generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_in_production_use_a_long_random_string
