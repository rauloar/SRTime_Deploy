# ============================================================
# SRTime Web — Variables de Entorno (Producción)
# Ubicación: /home/raul/proyectos/SRTime/attendance/.env
# ============================================================

# PostgreSQL (ya instalado en el servidor)
DB_ENGINE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USER=raul
DB_PASS=<CAMBIAR-contraseña-segura>
DB_NAME=srtime_attendance

# JWT Secret Key (generar con: python3 -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=<CAMBIAR-generar-key-segura>

# CORS — orígenes permitidos
# Para acceso LAN:    ["http://192.168.x.x"]
# Para dominio:       ["https://srtime.tuempresa.com"]
CORS_ORIGINS=["http://localhost"]

# URL de la API que el frontend usará
# Si Apache hace reverse proxy: usar la URL del servidor
NEXT_PUBLIC_API_URL=http://localhost:8000

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_DIR=/var/log/srtime
